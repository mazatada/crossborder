{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/hs_classification.json",
  "type": "object",
  "required": [
    "product_id",
    "hs_candidates",
    "review_required"
  ],
  "properties": {
    "product_id": {
      "type": "string",
      "format": "uuid"
    },
    "hs_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "code",
          "confidence"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[0-9]{4}(\\.[0-9]{2})?(\\.[0-9]{2})?$"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "rationale": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "required_uom": {
      "enum": [
        "kg",
        "l",
        "No."
      ]
    },
    "final_hs_code": {
      "type": "string"
    },
    "review_required": {
      "type": "boolean"
    }
  }
}