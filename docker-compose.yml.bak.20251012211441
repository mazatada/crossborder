services:
  backend:
    image: crossborder-backend:latest
    depends_on:
      db:
        condition: service_healthy
    environment:
      SQLALCHEMY_DATABASE_URI: "postgresql+psycopg://cb:cbpass@db:5432/cbdb"
      FLASK_ENV: development
    ports:
      - "5001:5000"

  db:
    image: postgres:16
    environment:
      POSTGRES_DB: cbdb
      POSTGRES_USER: cb
      POSTGRES_PASSWORD: cbpass
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U cb -d cbdb"]
      interval: 5s
      timeout: 3s
      retries: 10
    ports:
      - "5432:5432"
    volumes:
      - db_data:/var/lib/postgresql/data

volumes:
  db_data:
